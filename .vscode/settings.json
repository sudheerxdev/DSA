{
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "workbench.welcome.enabled": false,
  "workbench.layoutControl.enabled": false,
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabCloseButton": "right",
  "editor.fontSize": 16,
  "editor.lineHeight": 1.85,
  "editor.fontFamily": "'Consolas', 'Monaco', monospace",
  "editor.fontLigatures": true,
  "editor.fontWeight": "500",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 120,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.minimap.enabled": false,
  "editor.minimap.renderCharacters": false,
  "editor.rulers": [
    80,
    120
  ],
  "editor.renderWhitespace": "selection",
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.lineNumbers": "on",
  "editor.scrollBeyondLastLine": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.suggest.enabled": false,
  "editor.inlineSuggest.enabled": false,
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.parameterHints.enabled": false,
  "editor.formatOnType": true,
  "editor.autoClosingBrackets": "beforeWhitespace",
  "editor.autoClosingDelete": "beforeWhitespace",
  "editor.autoClosingQuotes": "beforeWhitespace",
  "editor.matchBrackets": "always",
  "editor.renderLineHighlight": "all",
  "editor.occurrencesHighlight": "on",
  "editor.selectionHighlight": true,
  "editor.selectionClipboard": true,
  "editor.smoothScrolling": true,
  "editor.snippetSuggestions": "top",
  "editor.accessibilitySupport": "off",
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.suggest.showMethods": false,
    "editor.suggest.showSnippets": true,
    "editor.suggest.showIssues": false,
    "editor.inlineSuggest.enabled": false,
    "editor.parameterHints.enabled": false,
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.formatOnType": true
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.formatOnType": true
  },
  "C_Cpp.formatting": "Default",
  "C_Cpp.intelliSenseEngine": "Default",
  "C_Cpp.intelliSenseEngineFallback": "Disabled",
  "C_Cpp.codeAnalysis.enabled": false,
  "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, IndentWidth: 4, UseTab: Never }",
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.vscode": false,
    "**/node_modules": true,
    "**/*.o": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/output": false,
    "**/debug": false
  },
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "'Consolas', monospace",
  "terminal.integrated.shell.windows": "powershell.exe",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.cursorBlinking": true,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.exe": "${basename}.cpp, ${basename}.c",
    ".gitignore": ".gitattributes, .gitmodules, .gitconfig"
  },
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  "window.title": "${dirty}${activeEditorShort}${separator}${folderName} - DSA Master",
  "window.zoomLevel": 0,
  "extensions.ignoreRecommendations": false,
  "extensions.recommendations": [
    "ms-vscode.cpptools",
    "ms-vscode.cpptools-extension-pack",
    "ms-vscode.cpptests",
    "xaver.theme-onedark-pro",
    "vscode-icons-team.vscode-icons",
    "eamodio.gitlens",
    "usernamehw.errorlens",
    "aaron-bond.better-comments",
    "Gruntfuggly.todo-tree",
    "ms-vscode-remote.remote-wsl",
    "sonarlint.sonarlint-vscode",
    "vadimcn.vscode-lldb",
    "codeforces.codeforces",
    "LeetCode.leetcode",
    "ms-vscode.makefile-tools",
    "jeff-hykin.better-cpp-syntax",
    "Peacock.peacock"
  ],
  "git.ignoreLimitWarning": true,
  "gitlens.advanced.maxSearchItems": 200,
  "gitlens.statusBar.enabled": true,
  "gitlens.statusBar.alignment": "left",
  "redhat.telemetry.enabled": false,
  "telemetry.telemetryLevel": "off",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "git.openRepositoryInParentFolders": true,
  "errorLens.enabled": true,
  "errorLens.followCursorMore": true,
  "errorLens.fontSize": 12,
  "todohighlight.isCaseSensitive": false,
  "todohighlight.keywords": [
    "TODO",
    "FIXME",
    "BUG",
    "HACK",
    "IMPORTANT",
    "OPTIMIZE",
    "DEBUG"
  ],
  "peacock.color": "#0d47a1",
  "workbench.editor.tabActionLocation": "right",
  "editor.guides.highlightActiveIndentation": true
}
