        "args": "Build Debug"
    },
    {
        "key": "ctrl+alt+shift+b",
        "command": "workbench.action.tasks.runTask",
        "args": "Build Release"
    },
    {
        "key": "ctrl+alt+r",
        "command": "workbench.action.tasks.runTask",
